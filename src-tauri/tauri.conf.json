{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CMD+K",
  "version": "0.3.11",
  "identifier": "com.lakshmanturlapati.cmd-k",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CMD+K",
        "width": 320,
        "height": 100,
        "minWidth": 320,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "visible": false,
        "center": true,
        "resizable": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/LakshmanTurlapati/Cmd-K/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5NENFQTFDQjJGNTlFNDMKUldSRG52V3lIT3BNNlI5eXlxUmtaU0NHcGt5ckZnb0xzOTFCZ0NQRzd0eUptTW05RDNPdFY1NTcK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../K.png", "../K-white.png"],
    "macOS": {
      "entitlements": "entitlements.plist",
      "signingIdentity": "Developer ID Application: VENKAT LUKSSHMAN TURLAPATI (36L722DZ7X)"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
